# Self-hosted: set the instance origin; /api is appended automatically.
UMAMI_URL=https://analytics.example.com

# Cloud alternative (use instead of UMAMI_URL):
# UMAMI_API_URL=https://api.umami.is/v1

# Choose exactly one authentication mode.
UMAMI_USERNAME=read-only-user
UMAMI_PASSWORD=change-me
# UMAMI_ACCESS_TOKEN=existing-bearer-token
# UMAMI_API_KEY=cloud-or-client-api-key

# Optional hardening and scope controls.
# UMAMI_WEBSITE_IDS=uuid-one,uuid-two
# UMAMI_TEAM_IDS=team-uuid-one,team-uuid-two
# Defaults to core,insights. Opt into more only when the client needs them:
# UMAMI_TOOLSETS=core,insights,events,sessions,performance,reports,revenue,replay,heatmaps
# UMAMI_REQUEST_TIMEOUT_MS=30000
# UMAMI_MAX_RANGE_DAYS=366
# UMAMI_MAX_RESPONSE_BYTES=10485760
# UMAMI_ALLOW_INSECURE_HTTP=false
